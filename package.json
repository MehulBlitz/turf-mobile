{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "android:build": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:debug": "cd android && gradlew assembleDebug",
    "android:release": "cd android && gradlew assembleRelease",
    "android:bundle": "cd android && gradlew bundleRelease",
    "android:install": "cd android && gradlew installDebug",
    "android:run": "npx cap run android",
    "android:sync": "npx cap sync android",
    "android:copy": "npx cap copy android",
    "ios:build": "npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:prebuild": "npx cap add ios",
    "ios:sync": "npx cap sync ios",
    "ios:copy": "npx cap copy ios",
    "ios:debug": "xcodebuild -workspace ios/App/App.xcworkspace -scheme App -configuration Debug -derivedDataPath build",
    "ios:release": "xcodebuild -workspace ios/App/App.xcworkspace -scheme App -configuration Release -derivedDataPath build",
    "ios:ipa": "xcodebuild -workspace ios/App/App.xcworkspace -scheme App -configuration Release -derivedDataPath build -arch arm64 -allowProvisioningUpdates archive -archivePath build/App.xcarchive && xcodebuild -exportArchive -archivePath build/App.xcarchive -exportOptionsPlist ios/ExportOptions.plist -exportPath build/ipa",
    "firebase:login": "npx firebase login",
    "firebase:deploy": "npm run build && npx firebase deploy --only hosting",
    "firebase:deploy:ci": "node scripts/firebase-deploy-ci.js",
    "firebase:deploy:sa": "node scripts/firebase-deploy-sa.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/network": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@capacitor/toast": "^8.0.1",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@untitledui/icons": "^0.0.22",
    "@vitejs/plugin-react": "^5.0.4",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "gh": "^2.8.9",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qr-code-styling": "^1.9.2",
    "react": "^19.0.0",
    "react-aria-components": "^1.16.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.0.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase": "^10.12.0",
    "firebase-tools": "^15.14.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "vite": "^6.2.0"
  }
}
