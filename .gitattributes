# Force LF line endings for all files
* text=auto eol=lf

# Explicitly set LF for YAML and workflow files
*.yml text eol=lf
*.yaml text eol=lf
.github/ text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.zip binary
*.ipa binary
*.apk binary
